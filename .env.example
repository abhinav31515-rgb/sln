APP_NAME=Laravel
# Production: APP_ENV=production (enables optimizations, disables debug features)
APP_ENV=local
APP_KEY=
# Production: APP_DEBUG=false (never expose debug info in production)
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Production: SESSION_ENCRYPT=true (encrypt session data)
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production: SESSION_SECURE_COOKIE=true (HTTPS only)
# Production: SESSION_SAME_SITE=strict (CSRF protection)

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Production: QUEUE_CONNECTION=redis (for reliable background job processing)
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
# Production: Use smtp mailer with your email service provider
MAIL_MAILER=log
MAIL_SCHEME=null
# Production: MAIL_HOST=smtp.mailtrap.io (or your SMTP server)
MAIL_HOST=127.0.0.1
# Production: MAIL_PORT=587 (TLS) or 465 (SSL)
MAIL_PORT=2525
# Production: MAIL_USERNAME=your-smtp-username
MAIL_USERNAME=null
# Production: MAIL_PASSWORD=your-smtp-password
MAIL_PASSWORD=null
# Production: MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
